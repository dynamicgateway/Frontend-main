{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run start",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_FORMIO_API_URL": "@formio_api_url",
    "VITE_FORMIO_PROJECT_URL": "@formio_project_url"
  },
  "build": {
    "env": {
      "VITE_FORMIO_API_URL": "@formio_api_url",
      "VITE_FORMIO_PROJECT_URL": "@formio_project_url"
    }
  }
}
