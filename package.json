  "scripts": {
    "start": "vite",
    "start:license_check": "NODE_ENV=dev && npm run license-check && vite",
    "license-check": "license-checker --onlyAllow \"BlueOak-1.0.0;MIT;X11;BSD;ISC;Apache-2.0;Python-2.0;MPL-2.0;CC-BY-4.0;CC-BY-3.0;CC0-1.0;WTFPL;Unlicense;UNLICENSED;Apache*\" --production",
    "build": "tsc --project tsconfig.json --noEmit && vite build",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint ./src",
    "lint-fix": "eslint --fix ./src",
    "generate-icons": "svgr --no-prettier --out-dir=src/assets/icons/dist -- src/assets/icons && prettier --write --cache src/assets/icons/dist"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": "eslint",
    "**/*.scss": "stylelint --config .stylelintrc",
    "*.ts": [
      "prettier --write",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
